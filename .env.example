ORACLE_USER=kg_swarm_user
ORACLE_PASSWORD=YourPassword123
ORACLE_DSN=localhost:1521/FREEPDB1
OPENAI_API_KEY=replace_with_your_openai_api_key
# Optional OpenAI-compatible endpoint. Example for Ollama:
# OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
# Request timeout and retry count for OpenAI-compatible chat/embedding calls.
OPENAI_TIMEOUT_SECONDS=300
OPENAI_MAX_RETRIES=2

# LLMs used by the parallel extractor ensemble.
EXTRACTOR_COUNT=3
EXTRACTOR_MODELS=gpt-4o,gpt-4o-mini,gpt-4o
EXTRACTOR_TEMPERATURES=0.0,0.0,0.0
# Optional. Values cycle if fewer than EXTRACTOR_COUNT.
EXTRACTOR_PROMPT_ANGLES=entity_first,relationship_first,balanced
EXTRACTION_BATCH_SIZE=30
# Keep triples limited to active ontology types and relationship signatures;
# missing reusable types go to ontology_candidates.
EXTRACTION_STRICT_ONTOLOGY=true
# 0 means one worker per configured extractor variant.
EXTRACTOR_PARALLEL_WORKERS=0
# Minimum number of extractors that must agree on a triple.
CONSENSUS_MIN_AGREEMENT=2
CONSENSUS_NAME_SIMILARITY_THRESHOLD=0.88

# Set FORCE_REPROCESS=1 to ignore prior extraction records for the same document.
FORCE_REPROCESS=0
# Save extractor outputs locally so graph-write retries do not redo LLM extraction.
EXTRACTION_CACHE_ENABLED=true
# Read saved extractor outputs. FORCE_REPROCESS=1 bypasses reads even when this is true.
EXTRACTION_CACHE_READ_ENABLED=true
CHUNK_CACHE_ENABLED=true
# Auto-admit new vertex/edge types into ontology after this many observations.
ONTOLOGY_AUTO_ADMIT_THRESHOLD=3
# Also require this many distinct extractors to propose the candidate type.
# 0 means use CONSENSUS_MIN_AGREEMENT.
ONTOLOGY_CANDIDATE_MIN_EXTRACTORS=0
# Comma-separated modules such as core,pharma,finance, or auto for deterministic detection.
ONTOLOGY_DOMAINS=auto
# External domain config with keywords, vertex types, and edge types.
DOMAIN_CONFIG_FILE=domain_config.json

# Agent Memory schema lifecycle.
# CREATE_IF_NECESSARY preserves existing memory. RECREATE wipes/rebuilds it.
AGENT_MEMORY_SCHEMA_POLICY=CREATE_IF_NECESSARY
# Keep Agent Memory limited to ontology type entries; entity reconciliation uses the graph.
AGENT_MEMORY_ONTOLOGY_ONLY=true

OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072

# Optional. Example: DEV_ creates DEV_KG_VERTEX and DEV_KG_EXTRACTION_GRAPH.
DB_OBJECT_PREFIX=SW1_
